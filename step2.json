test> use loan_analytics_db
switched to db loan_analytics_db
loan_analytics_db> db.loans.aggregate([
|   { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|   { $group: {
|       _id: { grade: "$grade", term: "$term", purpose: "$purpose" },
|       total_loans: { $sum: 1 },
|       avg_int_rate: { $avg: "$int_rate" },
|       default_count: { $sum: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } },
|       paid_count: { $sum: { $cond: [{ $eq: ["$loan_status", "Fully Paid"] }, 1, 0] } }
|   }},
|   { $project: {
|       grade: "$_id.grade",
|       term: "$_id.term",
|       purpose: "$_id.purpose",
|       default_rate: { $divide: ["$default_count", "$total_loans"] },
|       fully_paid_rate: { $divide: ["$paid_count", "$total_loans"] },
|       avg_int_rate: 1
|   }},
|   { $out: "dashboard_main_stats" }
| ])

loan_analytics_db> db.loans.aggregate([
|   { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|   { $group: {
|       _id: "$issue_d",
|       default_rate: { $avg: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } }
|   }},
|   { $out: "dashboard_trends" }
| ])

loan_analytics_db> db.loans.aggregate([
|   { $project: {
|       has_high_dti: { $cond: [{ $gt: ["$dti", 30] }, 1, 0] },
|       has_high_util: { $cond: [{ $gt: ["$revol_util", 80] }, 1, 0] },
|       has_delinq: { $cond: [{ $gt: ["$delinq_2yrs", 0] }, 1, 0] }
|   }},
|   { $group: {
|       _id: "Summary",
|       kpi4_dti_share: { $avg: "$has_high_dti" },
|       kpi5_util_share: { $avg: "$has_high_util" },
|       kpi6_delinq_share: { $avg: "$has_delinq" }
|   }},
|   { $out: "dashboard_kpi_cards" }
| ])

loan_analytics_db> db.loans.aggregate([
|   { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|   { $group: {
|       _id: "$issue_d",
|       default_rate: { $avg: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } }
|   }},
|   { $project: {
|       _id: 0,           // This hides the _id field
|       issue_date: "$_id", // This renames it back to issue_date
|       default_rate: 1
|   }},
|   { $sort: { issue_date: 1 } },
|   { $out: "final_trends_cleaned" }
| ])


