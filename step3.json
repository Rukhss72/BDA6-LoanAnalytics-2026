loan_analytics_db> db.loans.aggregate([
|    { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|    { $group: { _id: "$issue_d", total: { $sum: 1 }, def: { $sum: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } } } },
