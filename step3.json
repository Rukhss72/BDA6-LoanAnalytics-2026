|    { $out: "results_trends" }
| ])

loan_analytics_db> db.loans.aggregate([
|   { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|   { $group: {
|       _id: "$grade",
|       total_loans: { $sum: 1 },
|       defaults: { $sum: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } },
|       fully_paid: { $sum: { $cond: [{ $eq: ["$loan_status", "Fully Paid"] }, 1, 0] } }
|   }},
|   { $project: {
|       grade: "$_id",
|       default_rate: { $divide: ["$defaults", "$total_loans"] },
|       fully_paid_rate: { $divide: ["$fully_paid", "$total_loans"] }
|   }},
|   { $out: "csv_grade_risk" }
| ])

