loan_analytics_db> // 1. Calculate Grade Risk & Performance (KPI 1, 2 & Stakeholder Q1, Q5)
| db.loans.aggregate([
|   { $match: { loan_status: { $in: ["Fully Paid", "Charged Off", "Default"] } } },
|   { $group: {
|       _id: "$grade",
|       total: { $sum: 1 },
|       defaults: { $sum: { $cond: [{ $in: ["$loan_status", ["Charged Off", "Default"]] }, 1, 0] } },
|       paid: { $sum: { $cond: [{ $eq: ["$loan_status", "Fully Paid"] }, 1, 0] } }
|   }},
|   { $project: { grade: "$_id", default_rate: { $divide: ["$defaults", "$total"] }, fully_paid_rate: { $divide: ["$paid", "$total"] } } },
|   { $out: "final_grade_summary" }
| ]);
|
| // 2. Calculate Pricing Alignment (KPI 3 & Stakeholder Q2)
| db.loans.aggregate([
|   { $group: { _id: "$grade", avg_int_rate: { $avg: "$int_rate" } } },
|   { $out: "final_pricing_summary" }
| ]);
|
| // 3. Calculate Risk Indicators (KPI 4, 5, 6 & Stakeholder Q4)
| db.loans.aggregate([
|   { $group: {
|       _id: "Portfolio Wide",
|       kpi4_high_dti: { $avg: { $cond: [{ $gt: ["$dti", 30] }, 1, 0] } },
|       kpi5_high_util: { $avg: { $cond: [{ $gt: ["$revol_util", 80] }, 1, 0] } },
|       kpi6_delinq: { $avg: { $cond: [{ $gt: ["$delinq_2yrs", 0] }, 1, 0] } }
|   }},
|   { $out: "final_risk_indicators" }
| ]);

